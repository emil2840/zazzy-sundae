---
layout: base.njk
---
<article class="recipe-page">
  <a href="/" class="back-link">← Alle opskrifter</a>

  <header class="recipe-header">
    {% if tags and tags.length %}
    <div class="recipe-header__tags">
      {% for tag in tags %}
      <span class="recipe-header__tag">{{ tag }}</span>
      {% endfor %}
    </div>
    {% endif %}

    <h1 class="recipe-title">{{ title }}</h1>

    {% if description %}
    <p class="recipe-description">{{ description }}</p>
    {% endif %}

    <div class="recipe-meta">
      {% if cookTime %}
      <div class="recipe-meta__item">
        <span class="recipe-meta__label">Tilberedning</span>
        <span class="recipe-meta__value">{{ cookTime }} min</span>
      </div>
      {% endif %}

      <button class="recipe-menu-btn" aria-label="Opskriftshandlinger">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <circle cx="12" cy="5" r="2.2"/><circle cx="12" cy="12" r="2.2"/><circle cx="12" cy="19" r="2.2"/>
        </svg>
      </button>
    </div>
  </header>

  {% if image %}
  <figure class="recipe-image">
    <img src="/images/{{ image }}" alt="{{ title }}">
  </figure>
  {% endif %}

  <div class="recipe-body">
    {% if ingredients and ingredients.length %}
    <aside class="recipe-ingredients" data-servings="{{ servings or 4 }}">
      <div class="serving-counter">
        <span class="serving-counter__label">Portioner</span>
        <div class="serving-counter__controls">
          <button class="serving-counter__btn" data-action="decrease" aria-label="Færre portioner">−</button>
          <span class="serving-counter__value">{{ servings or 4 }}</span>
          <button class="serving-counter__btn" data-action="increase" aria-label="Flere portioner">+</button>
        </div>
      </div>
      <h2>Ingredienser</h2>
      <ul>
        {% for item in ingredients %}
        <li data-original="{{ item }}">{{ item }}</li>
        {% endfor %}
      </ul>
    </aside>
    {% endif %}

    <div class="recipe-content">
      {{ content | safe }}
    </div>
  </div>
</article>

<!-- Bottom sheet -->
<div class="recipe-sheet" role="dialog" aria-modal="true" aria-label="Ingrediensliste" hidden>
  <div class="recipe-sheet__backdrop"></div>
  <div class="recipe-sheet__panel">
    <div class="recipe-sheet__handle"></div>

    <div class="recipe-sheet__header">
      <div class="recipe-sheet__header-row">
        <h2 class="recipe-sheet__title"></h2>
        <button class="recipe-sheet__pdf-btn" aria-label="Gem som PDF">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            <line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>
          </svg>
          PDF
        </button>
      </div>
      <div class="recipe-sheet__serving">
        <span class="recipe-sheet__serving-label">Portioner</span>
        <div class="serving-counter__controls">
          <button class="serving-counter__btn" data-modal-action="decrease" aria-label="Færre portioner">−</button>
          <span class="recipe-sheet__serving-value"></span>
          <button class="serving-counter__btn" data-modal-action="increase" aria-label="Flere portioner">+</button>
        </div>
      </div>
    </div>

    <ul class="recipe-sheet__list"></ul>

    <div class="recipe-sheet__actions">
      <button class="recipe-sheet__btn recipe-sheet__btn--notes">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        Gem i Notes
      </button>
      <button class="recipe-sheet__btn recipe-sheet__btn--share">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
        </svg>
        Del
      </button>
    </div>

    <button class="recipe-sheet__close">Luk</button>
  </div>
</div>

<script>
(function () {
  var aside = document.querySelector('.recipe-ingredients');
  if (!aside) return;

  var base = parseInt(aside.dataset.servings, 10) || 4;
  var count = base;
  var countEl = aside.querySelector('.serving-counter__value');
  var items = aside.querySelectorAll('li[data-original]');

  function scale(text, ratio) {
    return text.replace(/^(\d+(?:[.,]\d+)?)/, function (m) {
      var n = parseFloat(m.replace(',', '.')) * ratio;
      return n % 1 === 0 ? String(Math.round(n)) : String(Math.round(n * 10) / 10);
    });
  }

  function render() {
    countEl.textContent = count;
    items.forEach(function (li) {
      li.textContent = scale(li.dataset.original, count / base);
    });
  }

  aside.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-action]');
    if (!btn) return;
    if (btn.dataset.action === 'increase') count = Math.min(count + 1, 20);
    if (btn.dataset.action === 'decrease') count = Math.max(count - 1, 1);
    render();
  });

  var sheet        = document.querySelector('.recipe-sheet');
  var panel        = sheet.querySelector('.recipe-sheet__panel');
  var backdrop     = sheet.querySelector('.recipe-sheet__backdrop');
  var sheetTitle   = sheet.querySelector('.recipe-sheet__title');
  var sheetServing = sheet.querySelector('.recipe-sheet__serving-value');
  var sheetList    = sheet.querySelector('.recipe-sheet__list');
  var btnNotes     = sheet.querySelector('.recipe-sheet__btn--notes');
  var btnShare     = sheet.querySelector('.recipe-sheet__btn--share');
  var btnClose     = sheet.querySelector('.recipe-sheet__close');
  var menuBtn      = document.querySelector('.recipe-menu-btn');

  var modalCount = count;
  var recipeTitle = (document.querySelector('.recipe-title') || {}).textContent || '';
  recipeTitle = recipeTitle.trim();

  /* ── Swipe to close — kun på handle-bar ── */
  var startY = 0, currentY = 0;
  // Swipe-zone: handle + header (men ikke knapper/inputs)
  var dragZone = panel.querySelector('.recipe-sheet__header');

  dragZone.addEventListener('touchstart', function (e) {
    if (e.target.closest('button, input, label')) return;
    startY = e.touches[0].clientY;
    currentY = startY;
    panel.style.transition = 'none';
  }, { passive: true });

  dragZone.addEventListener('touchmove', function (e) {
    if (startY === 0) return;
    currentY = e.touches[0].clientY;
    var diff = Math.max(0, currentY - startY);
    panel.style.transform = 'translateY(' + diff + 'px)';
  }, { passive: true });

  dragZone.addEventListener('touchend', function () {
    if (startY === 0) return;
    panel.style.transition = '';
    var moved = currentY - startY;
    startY = 0;
    if (moved > 80) { closeSheet(); }
    else { panel.style.transform = ''; }
  });

    function openSheet() {
    modalCount = count;
    sheetServing.textContent = modalCount;
    sheetTitle.textContent = recipeTitle;
    buildList();
    sheet.hidden = false;
    requestAnimationFrame(function () { sheet.classList.add('is-open'); });
    document.body.style.overflow = 'hidden';
  }

  function closeSheet() {
    sheet.classList.remove('is-open');
    panel.style.transform = 'translateY(100%)';
    setTimeout(function () {
      sheet.hidden = true;
      panel.style.transform = '';
      document.body.style.overflow = '';
    }, 320);
  }

  function buildList() {
    sheetList.innerHTML = '';
    items.forEach(function (li) {
      var scaled = scale(li.dataset.original, modalCount / base);
      var row = document.createElement('li');
      row.className = 'recipe-sheet__item';
      var cb = document.createElement('input');
      cb.type = 'checkbox'; cb.checked = true;
      cb.id = 'ing-' + Math.random().toString(36).slice(2);
      var label = document.createElement('label');
      label.htmlFor = cb.id;
      var span = document.createElement('span');
      span.textContent = scaled;
      span.dataset.original = li.dataset.original;
      label.appendChild(span);
      row.appendChild(cb); row.appendChild(label);
      sheetList.appendChild(row);
    });
  }

  function getChecked() {
    return Array.from(sheetList.querySelectorAll('li'))
      .filter(function (li) { return li.querySelector('input').checked; })
      .map(function (li) { return li.querySelector('span').textContent; });
  }

  if (menuBtn) menuBtn.addEventListener('click', openSheet);
  btnClose.addEventListener('click', closeSheet);
  backdrop.addEventListener('click', function (e) { if (e.target === backdrop) closeSheet(); });
  sheet.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeSheet(); });

  sheet.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-modal-action]');
    if (!btn) return;
    if (btn.dataset.modalAction === 'increase') modalCount = Math.min(modalCount + 1, 20);
    if (btn.dataset.modalAction === 'decrease') modalCount = Math.max(modalCount - 1, 1);
    sheetServing.textContent = modalCount;
    Array.from(sheetList.querySelectorAll('li')).forEach(function (row) {
      var span = row.querySelector('span');
      span.textContent = scale(span.dataset.original, modalCount / base);
    });
  });

  btnNotes.addEventListener('click', function () {
    var selected = getChecked();
    if (!selected.length) return;
    var text = '🛒 ' + recipeTitle + ' (' + modalCount + ' pers.)\n\n' +
               selected.map(function (i) { return '☐ ' + i; }).join('\n');
    var encoded = encodeURIComponent(text);
    var left = false;
    var timer = setTimeout(function () {
      if (!left && navigator.share) navigator.share({ text: text }).catch(function(){});
    }, 1500);
    document.addEventListener('visibilitychange', function onVis() {
      if (document.hidden) { left = true; clearTimeout(timer); document.removeEventListener('visibilitychange', onVis); }
    });
    window.location.href = 'shortcuts://run-shortcut?name=Indkøbsliste&input=' + encoded;
  });

  btnShare.addEventListener('click', function () {
    var selected = getChecked();
    if (!selected.length) return;
    var text = selected.map(function (i) { return '• ' + i; }).join('\n');
    if (navigator.share) { navigator.share({ text: text }).catch(function(){}); }
    else { navigator.clipboard && navigator.clipboard.writeText(text).then(function(){ alert('Kopieret!'); }); }
  });

})();
</script>
